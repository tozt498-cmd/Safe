# Connection string Postgres (Neon, Supabase, ou Postgres local). OBLIGATOIRE.
# Exemple Neon : postgresql://user:password@host.neon.tech/db?sslmode=require
DATABASE_URL=

# Secret de signature des JWT — valeur aléatoire longue (openssl rand -hex 48).
JWT_SECRET=change-me-to-a-long-random-secret-please

# Durée de vie des sessions JWT
JWT_EXPIRES_IN=30d

# Port (en local). En production (Render), la plateforme fournit PORT automatiquement.
PORT=4317

# Origines autorisées (CORS). L'app Electron n'a pas d'origine web fixe -> * convient.
CORS_ORIGIN=*

# Clé d'activation admin (laisser vide : générée auto au 1er démarrage, affichée dans les logs).
SEED_ADMIN_KEY=
