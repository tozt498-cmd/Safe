# Port du serveur API + WebSocket
PORT=4317

# Secret de signature des JWT — REMPLACEZ par une valeur aléatoire longue en production
JWT_SECRET=change-me-to-a-long-random-secret-please

# Durée de vie des sessions JWT
JWT_EXPIRES_IN=30d

# Origines autorisées (CORS). L'app Electron utilise un origin file:// -> on autorise tout en dev.
CORS_ORIGIN=*

# Clé d'activation admin générée au premier démarrage (laisser vide pour génération auto).
# La clé générée s'affichera dans la console au premier lancement.
SEED_ADMIN_KEY=
